# Приватное хранилище данных приложения.
WB_PRIVATE_DIR=./wb-private

# Базовая авторизация панели.
APP_AUTH_ENABLED=true
APP_ADMIN_USERNAME=admin
# Для production используйте хеш пароля, а не открытый текст.
# Формат: pbkdf2_sha256$240000$<salt_hex>$<hash_hex>
APP_ADMIN_PASSWORD_HASH=
# APP_ADMIN_PASSWORD=оставьте пустым; это legacy-режим только для временной совместимости
APP_ADMIN_LOGIN_MAX_ATTEMPTS=5
APP_ADMIN_LOGIN_LOCK_SECONDS=300
APP_REQUIRE_CSRF_FOR_AUTH_FORMS=true

# Секрет Flask. Если не задан, будет автоматически создан в WB_PRIVATE_DIR/security/flask_secret.txt
# FLASK_SECRET=
FLASK_DEBUG=false

# Безопасность cookie.
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Strict
# Для production за reverse proxy/https должно быть true.
SESSION_COOKIE_SECURE=true
PERMANENT_SESSION_LIFETIME_HOURS=12

# Лимиты форм и загрузок.
MAX_FORM_MEMORY_SIZE=8388608
MAX_FORM_PARTS=400
MAX_CONTENT_LENGTH_MB=256

# Интеграции.
WB_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.hydraai.ru/v1
OPENAI_MODEL=gpt-4o-mini

# Browser / Playwright.
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_BROWSER_CHANNEL=
PLAYWRIGHT_SLOW_MO_MS=150
PLAYWRIGHT_DEFAULT_TIMEOUT_MS=15000
PLAYWRIGHT_NAVIGATION_TIMEOUT_MS=45000
WB_BROWSER_ALLOWED_NAV_HOSTS=seller.wildberries.ru
WB_BROWSER_ALLOWED_REQUEST_SUFFIXES=wildberries.ru,wb.ru,wbstatic.net

# Background jobs.
BACKGROUND_JOB_MAX_WORKERS=4
BACKGROUND_JOB_STALE_SECONDS=21600
BACKGROUND_JOB_HISTORY_LIMIT=300

# Automation scheduler.
AUTOMATION_SCHEDULER_ENABLED=true
AUTOMATION_SCHEDULER_POLL_SECONDS=30
# true = scheduler живёт внутри app.py, false = запускается отдельным worker-процессом
# Для отдельного scheduler-worker рекомендуемый режим ниже.
AUTOMATION_SCHEDULER_EMBEDDED=false
AUTOMATION_RUNNER_MODE=external

# Ограничение bootstrap-страницы только локальной машиной (рекомендуется для продакшн-развёртываний)
APP_SETUP_LOCAL_ONLY=true
