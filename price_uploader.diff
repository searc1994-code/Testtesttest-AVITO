+def _dom_smart_click(
+    page,
+    *,
+    root_selectors: Sequence[str] = (),
+    candidate_selectors: Sequence[str] = (),
+    target_texts: Sequence[str] = (),
+    forbidden_texts: Sequence[str] = (),
+    prefer_testids: Sequence[str] = (),
+    prefer_class_fragments: Sequence[str] = (),
+    min_score: int = 100,
+) -> Optional[str]:
+    roots = [_clean(item) for item in root_selectors if _clean(item)]
+    selectors = [_clean(item) for item in candidate_selectors if _clean(item)]
+    targets = [_clean(item) for item in target_texts if _clean(item)]
+    forbidden = [_clean(item) for item in forbidden_texts if _clean(item)]
+    testids = [_clean(item) for item in prefer_testids if _clean(item)]
+    classes = [_clean(item) for item in prefer_class_fragments if _clean(item)]
+    script = """
+(args) => {
+  const normalize = (value) => String(value || '').replace(/\\s+/g, ' ').trim().toLowerCase();
+  const roots = Array.isArray(args?.roots) ? args.roots : [];
+  const selectors = Array.isArray(args?.selectors) ? args.selectors : [];
+  const targets = (Array.isArray(args?.targets) ? args.targets : []).map(normalize).filter(Boolean);
+  const forbidden = (Array.isArray(args?.forbidden) ? args.forbidden : []).map(normalize).filter(Boolean);
+  const testids = (Array.isArray(args?.testids) ? args.testids : []).map(normalize).filter(Boolean);
+  const classFragments = (Array.isArray(args?.classes) ? args.classes : []).map(normalize).filter(Boolean);
+  const minScore = Number(args?.minScore || 100);
+  const defaultSelectors = ['button', '[role="button"]', '[role="menuitem"]', 'li', 'div', 'span'];
+  const rootNodes = roots.length ? roots.map((selector) => document.querySelector(selector)).filter(Boolean) : [document.body];
+  const fire = (node, type, Ctor, extra = {}) => {
+    try {
+      node.dispatchEvent(new Ctor(type, Object.assign({bubbles:true, cancelable:true, composed:true}, extra)));
+      return true;
+    } catch (e) {
+      return false;
+    }
+  };
+  let bestNode = null;
+  let bestScore = -Infinity;
+  let bestReason = '';
+  for (const root of rootNodes) {
+    const rawSelectors = selectors.length ? selectors : defaultSelectors;
+    const nodes = [];
+    for (const selector of rawSelectors) {
+      try {
+        for (const node of Array.from(root.querySelectorAll(selector))) {
+          nodes.push(node);
+        }
+      } catch (e) {}
+    }
+    if (!nodes.length) {
+      nodes.push(...Array.from(root.querySelectorAll(defaultSelectors.join(','))));
+    }
+    for (const node of nodes) {
+      const clickable = node.closest('button,[role="button"],[role="menuitem"],li,div,span') || node;
+      const text = normalize(clickable.innerText || clickable.textContent || '');
+      if (!text) continue;
+      let score = 0;
+      for (const target of targets) {
+        if (text === target) score += 240;
+        else if (text.includes(target)) score += 140;
+      }
+      if (targets.length === 0) score += 40;
+      for (const bad of forbidden) {
+        if (text.includes(bad)) score -= 180;
+      }
+      const testid = normalize(clickable.getAttribute('data-testid') || '');
+      for (const pref of testids) {
+        if (testid.includes(pref)) score += 80;
+      }
+      const className = normalize(clickable.className || '');
+      for (const frag of classFragments) {
+        if (className.includes(frag)) score += 25;
+      }
+      const rect = clickable.getBoundingClientRect();
+      if (rect.width <= 0 || rect.height <= 0) score -= 200;
+      const style = window.getComputedStyle(clickable);
+      if (style.display === 'none' || style.visibility === 'hidden' || style.pointerEvents === 'none') score -= 200;
+      if (score > bestScore) {
+        bestScore = score;
+        bestNode = clickable;
+        bestReason = `${testid || className || clickable.tagName}:${score}:${text.slice(0, 80)}`;
+      }
+    }
+  }
+  if (!bestNode || bestScore < minScore) return '';
+  try { bestNode.scrollIntoView({block:'center', inline:'center'}); } catch (e) {}
+  try { bestNode.focus?.(); } catch (e) {}
+  fire(bestNode, 'pointerdown', window.PointerEvent || MouseEvent, {pointerType:'mouse', buttons:1});
+  fire(bestNode, 'mousedown', MouseEvent, {buttons:1});
+  fire(bestNode, 'pointerup', window.PointerEvent || MouseEvent, {pointerType:'mouse', buttons:0});
+  fire(bestNode, 'mouseup', MouseEvent, {buttons:0});
+  try { bestNode.click?.(); } catch (e) {}
+  fire(bestNode, 'click', MouseEvent, {buttons:0});
+  return bestReason;
+}
+"""
+    try:
+        result = _clean(
+            page.evaluate(
+                script,
+                {
+                    "roots": roots,
+                    "selectors": selectors,
+                    "targets": targets,
+                    "forbidden": forbidden,
+                    "testids": testids,
+                    "classes": classes,
+                    "minScore": min_score,
+                },
+            )
+        )
+    except Exception:
+        result = ""
+    return result or None
+
