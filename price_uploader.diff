+
+    smart_result = _dom_smart_click(
+        page,
+        root_selectors=profile.get("open_upload_dropdown_selectors") or [],
+        candidate_selectors=option_selectors,
+        target_texts=option_texts,
+        forbidden_texts=forbidden_texts,
+        prefer_testids=["xlsx-action-options-test-id-dropdown-option", "xlsx-action-options"],
+        prefer_class_fragments=["Dropdown-option", "Dropdown-list__item"],
+        min_score=90,
+    )
+    if smart_result:
+        return f"smart:{smart_result}"
+    return None
+
